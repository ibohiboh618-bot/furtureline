{
  "name": "fixtureline",
  "version": "0.1.0",
  "description": "Telegram fan bot for the TxODDS World Cup hackathon: live updates, AI-suggested predictions, and on-chain verified results.",
  "private": true,
  "scripts": {
    "start": "npm run bot",
    "bot": "node bot/index.js",
    "ingest:odds": "node ingestion/workers/odds-listener.js",
    "ingest:scores": "node ingestion/workers/score-listener.js",
    "db:migrate": "node scripts/apply-schema.js",
    "db:bootstrap": "node scripts/bootstrap-session.js",
    "verify-service": "node ingestion/txodds/verify-service.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.3",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "eventsource": "^3.0.2",
    "grammy": "^1.30.0",
    "groq-sdk": "^0.7.0",
    "pg": "^8.13.0",
    "tweetnacl": "^1.0.3"
  }
}

