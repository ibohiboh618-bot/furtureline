{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install --legacy-peer-deps --omit=optional --no-audit"
  },
  "deploy": {
    "startCommand": "npm run start:railway"
  },
  "nixpacks": {
    "plan": {
      "phases": {
        "install": {
          "cmds": [
            "npm install --legacy-peer-deps --omit=optional --no-audit"
          ]
        },
        "build": {
          "cmds": []
        }
      }
    }
  }
}
